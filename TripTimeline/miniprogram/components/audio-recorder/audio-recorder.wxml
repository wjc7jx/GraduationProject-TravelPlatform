<!-- components/audio-recorder/audio-recorder.wxml -->
<view class="ar-container">

  <!-- ════ IDLE ════ -->
  <view wx:if="{{phase === 'idle' && !readonly}}" class="ar-idle">
    <view class="ar-idle-actions">
      <view class="ar-idle-btn ar-idle-btn--rec" bindtap="startRecord">
        <app-icon class="ar-idle-btn-icon" name="microphone" size="44rpx"></app-icon>
        <text class="ar-idle-btn-label">录音</text>
      </view>
      <view class="ar-idle-sep"></view>
      <view class="ar-idle-btn ar-idle-btn--file" bindtap="chooseFile">
        <app-icon class="ar-idle-btn-icon" name="folder" size="44rpx"></app-icon>
        <text class="ar-idle-btn-label">选择文件</text>
      </view>
    </view>
    <text class="ar-idle-hint">支持 MP3 / M4A / WAV · 最长 60 秒</text>
  </view>

  <!-- ════ RECORDING ════ -->
  <view wx:if="{{phase === 'recording'}}" class="ar-recording">
    <view class="ar-mic-wrap" bindtap="stopRecord">
      <view class="ar-mic-ripple ar-mic-ripple--1"></view>
      <view class="ar-mic-ripple ar-mic-ripple--2"></view>
      <view class="ar-mic-core">
        <app-icon class="ar-mic-emoji" name="microphone" size="36rpx"></app-icon>
      </view>
    </view>
    <view class="ar-rec-status">
      <view class="ar-rec-dot"></view>
      <text class="ar-rec-label">REC</text>
      <text class="ar-rec-timer">{{recordingTimeDisplay}}</text>
    </view>
    <view class="ar-rec-track">
      <view class="ar-rec-fill" style="width: {{recordingProgress}}%"></view>
    </view>
    <text class="ar-rec-hint">轻触麦克风停止 · 最长 1:00</text>
  </view>

  <!-- ════ UPLOADING ════ -->
  <view wx:if="{{phase === 'uploading'}}" class="ar-uploading">
    <view class="ar-spin-ring"></view>
    <text class="ar-upload-text">{{uploadingText}}</text>
  </view>

  <!-- ════ READY — Custom Player ════ -->
  <view wx:if="{{phase === 'ready'}}" class="ar-ready">
    <view class="ar-player">
      <view class="ar-play-btn {{isPlaying ? 'ar-play-btn--playing' : ''}}" bindtap="togglePlay">
        <app-icon wx:if="{{isPlaying}}" class="ar-play-icon" name="pause" size="28rpx"></app-icon>
        <app-icon wx:else class="ar-play-icon" name="play" size="28rpx"></app-icon>
      </view>
      <view class="ar-player-body">
        <text class="ar-filename">{{displayName}}</text>
        <slider
          class="ar-slider"
          min="0"
          max="{{duration > 0 ? duration : 1}}"
          value="{{currentTime}}"
          activeColor="#1f3d31"
          backgroundColor="rgba(42,75,60,0.18)"
          block-size="12"
          bindchanging="onSliderChanging"
          bindchange="onSliderChange"
        />
        <view class="ar-time-row">
          <text class="ar-time-label">{{currentTimeDisplay}}</text>
          <text class="ar-time-label">{{durationDisplay}}</text>
        </view>
      </view>
      <view wx:if="{{!readonly}}" class="ar-delete-btn" bindtap="removeAudio">
        <app-icon class="ar-delete-icon" name="close" size="22rpx"></app-icon>
      </view>
    </view>
    <view wx:if="{{!readonly}}" class="ar-change-row">
      <view class="ar-change-btn" bindtap="changeAudio">更换音频</view>
    </view>
  </view>

</view>
