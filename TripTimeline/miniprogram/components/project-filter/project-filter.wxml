<view class="filter-wrap">
  <view class="search-row">
    <input
      class="search-input"
      type="text"
      placeholder="搜索项目名称"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onKeywordConfirm"
      confirm-type="search"
    />
    <view class="filter-trigger" bindtap="toggleAdvanced">
      <view class="filter-icon"></view>
    </view>
  </view>

  <view wx:if="{{showAdvanced}}" class="advanced-layer">
    <view class="overlay" bindtap="closeAdvanced"></view>
    <view class="bottom-sheet" catchtap="noop">
      <view class="sheet-header">
        <view class="sheet-title">高级筛选</view>
        <view class="sheet-close" bindtap="closeAdvanced">关闭</view>
      </view>

      <view class="advanced-panel">
        <view class="field-row">
          <view class="field-label">标签</view>
          <input
            class="field-input"
            type="text"
            placeholder="输入标签关键字"
            value="{{tag}}"
            bindinput="onTagInput"
          />
        </view>

        <view class="field-row">
          <view class="field-label">开始日期</view>
          <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
            <view class="picker-value">{{startDate || '不限'}}</view>
          </picker>
        </view>

        <view class="field-row">
          <view class="field-label">结束日期</view>
          <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
            <view class="picker-value">{{endDate || '不限'}}</view>
          </picker>
        </view>
      </view>

      <view class="actions">
        <button class="clear-btn" size="mini" bindtap="onClear">清空</button>
        <button class="apply-btn" size="mini" bindtap="onApply">确定</button>
      </view>
    </view>
  </view>
</view>
