<view class="filter-wrap">
  <view class="search-row">
    <view class="search-box">
      <icon type="search" size="14" color="#8A877E"></icon>
      <input
        class="search-input"
        type="text"
        placeholder="搜索项目名称..."
        placeholder-style="color: #8A877E;"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="onKeywordConfirm"
        confirm-type="search"
      />
    </view>
    <view class="filter-trigger" bindtap="toggleAdvanced">
      <image class="filter-icon" src="/assets/img/filter.svg" mode="aspectFit"></image>
    </view>
  </view>

  <view wx:if="{{showAdvanced}}" class="advanced-layer">
    <view class="overlay" bindtap="closeAdvanced"></view>
    <view class="bottom-sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-header">
        <view class="sheet-title">高级筛选</view>
      </view>

      <view class="filter-section">
        <view class="section-label">项目标签</view>
        <input
          class="custom-input"
          type="text"
          placeholder="请输入标签关键字..."
          placeholder-style="color: #999C99;"
          value="{{tag}}"
          bindinput="onTagInput"
        />
      </view>

      <view class="filter-section">
        <view class="section-label">时间范围</view>
        <view class="date-range-row">
          <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange" class="date-picker">
            <view class="date-box {{startDate ? 'has-value' : ''}}">{{startDate || '开始日期'}}</view>
          </picker>
          <view class="date-separator">至</view>
          <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange" class="date-picker">
            <view class="date-box {{endDate ? 'has-value' : ''}}">{{endDate || '结束日期'}}</view>
          </picker>
        </view>
      </view>

      <view class="actions">
        <button class="btn-reset" bindtap="onClear" hover-class="btn-hover">重置</button>
        <button class="btn-apply" bindtap="onApply" hover-class="btn-hover">查看结果</button>
      </view>
    </view>
  </view>
</view>
