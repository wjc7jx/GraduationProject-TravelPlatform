<navigation-bar title="记录详情" back="{{true}}" color="#1C1C1C" background="transparent"></navigation-bar>

<scroll-view class="detail-scroll" scroll-y>
  <view class="detail-container fade-up" bindtap="onRecordTap">
    <view wx:if="{{loading}}" class="loading-text">加载中...</view>

    <block wx:else>
      <view wx:if="{{reviewFlagged}}" class="review-banner" catchtap="noop">
        <view class="review-banner-title">⚠ 该记录存在合规风险，暂无法导出或分享</view>
        <view class="review-banner-desc">请点击下方「编辑当前记录」修改后重新保存，系统会自动重新检测。</view>
      </view>
      <view wx:elif="{{reviewPending}}" class="review-banner review-banner-pending" catchtap="noop">
        <view class="review-banner-title">内容安全审核中</view>
        <view class="review-banner-desc">检测完成后即可导出或分享，请稍候。</view>
      </view>
      <view class="tip-text">{{isProjectArchived ? '当前项目已归档，仅可查看记录' : '点击卡片进入编辑'}}</view>

      <view class="meta-row">
        <view class="chip">{{typeLabel}}</view>
        <view class="time-text">{{dateText}} {{timeText}}</view>
      </view>

      <view class="title">{{title}}</view>
      <rich-text wx:if="{{content}}" class="content" nodes="{{content}}"></rich-text>

      <view wx:if="{{locationName || locationAddress}}" class="location-box">
        <view class="location-title">地点</view>
        <view wx:if="{{locationName}}" class="location-line">{{locationName}}</view>
        <view wx:if="{{locationAddress}}" class="location-sub">{{locationAddress}}</view>
      </view>

      <view wx:if="{{images.length > 0}}" class="media-block">
        <image wx:for="{{images}}" wx:key="*this" class="detail-image" src="{{item}}" mode="widthFix"></image>
      </view>

      <view wx:if="{{audioUrl}}" class="audio-block" catchtap="noop">
        <view class="section-title">音频</view>
        <audio-recorder value="{{audioValue}}" readonly="{{true}}"></audio-recorder>
      </view>

      <view wx:if="{{!isProjectArchived}}" class="edit-btn" bindtap="goToEdit">编辑当前记录</view>
    </block>
  </view>
</scroll-view>
