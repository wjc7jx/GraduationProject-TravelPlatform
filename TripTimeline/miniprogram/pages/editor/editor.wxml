<!--pages/editor/editor.wxml-->
<navigation-bar title="{{pageTitle}}" back="{{true}}" color="#1C1C1C" background="transparent"></navigation-bar>

<scroll-view class="editor-scroll" scroll-y>
  <view class="editor-container fade-up">
    <view class="page-head">
      <view class="page-title">此刻，值得记录</view>
      <view class="page-subtitle">{{pageSubtitle}}</view>
    </view>

    <!-- 文字区域（常驻，不受媒体类型控制） -->
    <view class="text-section form-card">
      <input
        class="title-input"
        placeholder="给这个瞬间一个名字"
        placeholder-class="ph-title"
        value="{{title}}"
        bindinput="onTitleInput"
      />
      <view class="text-divider"></view>
      <editor
        id="editor"
        class="body-editor"
        placeholder="写下当时的感受..."
        bindready="onEditorReady"
        bindinput="onEditorInput"
        bindstatuschange="onStatusChange"
      ></editor>
    </view>

    <!-- 音频附件区 -->
    <view wx:if="{{showAudioPanel}}" class="asset-section form-card">
      <view class="asset-section-header">
        <view class="asset-section-title">
          <app-icon class="asset-section-title-icon" name="microphone" size="32rpx"></app-icon>
          <text>音频</text>
        </view>
      </view>
      <audio-recorder
        value="{{audioValue}}"
        bindaudiochange="onAudioChange"
        bindaudioremove="onAudioRemove"
      />
    </view>

    <!-- 时间 & 地点信息卡 -->
    <view class="info-card form-card">

      <!-- 日期时间（合并单行） -->
      <view class="info-row datetime-row">
        <app-icon class="info-icon" name="clock" size="40rpx"></app-icon>
        <view class="info-body">
          <view class="info-label">时间</view>
          <view class="datetime-pickers">
            <picker mode="date" value="{{date}}" bindchange="bindDateChange">
              <view class="picker-val">{{date}}</view>
            </picker>
            <text class="datetime-sep">·</text>
            <picker mode="time" value="{{time}}" bindchange="bindTimeChange">
              <view class="picker-val">{{time}}</view>
            </picker>
          </view>
        </view>
      </view>

      <view class="info-divider"></view>

      <!-- 地点折叠入口 -->
      <view class="info-row location-entry" bindtap="toggleLocation">
        <app-icon class="info-icon" name="location" size="40rpx"></app-icon>
        <view class="info-body">
          <view class="info-label">地点</view>
          <view class="location-summary {{locationName ? '' : 'empty'}}">{{locationName || '添加地点'}}</view>
        </view>
        <text class="expand-arrow">{{locationExpanded ? '︿' : '﹀'}}</text>
      </view>

      <!-- 展开的地点详情面板 -->
      <view wx:if="{{locationExpanded}}" class="location-panel">
        <view class="search-row">
          <input
            class="form-input search-input"
            placeholder="搜索地点，如：西湖、天安门"
            value="{{locationSearchKeyword}}"
            bindinput="onLocationSearchInput"
            confirm-type="search"
            bindconfirm="searchLocationByKeyword"
          />
          <view class="search-btn" bindtap="searchLocationByKeyword">{{isLocationSearching ? '搜索中' : '搜索'}}</view>
        </view>
        <view wx:if="{{locationSuggestions.length > 0}}" class="suggestions-list">
          <view
            wx:for="{{locationSuggestions}}"
            wx:key="id"
            class="suggestion-item"
            data-index="{{index}}"
            bindtap="selectSuggestion"
          >
            <view class="suggestion-title">{{item.title}}</view>
            <view class="suggestion-address">{{item.address}}</view>
          </view>
        </view>
        <view class="location-manual-fields">
          <input
            class="form-input"
            placeholder="地点名称（可手动调整）"
            value="{{locationName}}"
            bindinput="onLocationNameInput"
          />
          <input
            class="form-input"
            placeholder="详细地址（可选）"
            value="{{locationAddress}}"
            bindinput="onLocationAddressInput"
          />
        </view>
        <view wx:if="{{autoFillHint}}" class="hint-text">{{autoFillHint}}</view>
        <map
          wx:if="{{locationMarker.length > 0}}"
          class="location-map"
          latitude="{{location.lat}}"
          longitude="{{location.lon}}"
          scale="16"
          markers="{{locationMarker}}"
          show-location="{{true}}"
        ></map>
        <view class="coord-text" wx:if="{{locationMarker.length > 0}}">
          {{location.lat}}, {{location.lon}}
        </view>
      </view>
    </view>

    <!-- 隐私设置 -->
    <view class="form-card privacy-block">
      <view class="privacy-title">隐私设置</view>
      <view class="privacy-summary">{{privacySummary}}</view>
      <view class="privacy-whitelist-wrap">
        记录隐私统一继承项目设置，如需调整请前往项目详情页修改。
      </view>
    </view>
    
    <!-- 提交按钮（三态）预留底部间距给Toolbar -->
    <view class="action-section" style="padding-bottom: env(safe-area-inset-bottom); margin-bottom: 120rpx;">
      <view
        class="save-btn save-btn--{{submitStatus}} {{submitStatus === 'error' ? 'shake' : ''}} {{submitStatus === 'loading' ? 'disabled' : ''}}"
        bindtap="saveEntry"
      >
        <block wx:if="{{submitStatus === 'loading'}}">保存中...</block>
        <block wx:elif="{{submitStatus === 'success'}}">✓ 已记录</block>
        <block wx:elif="{{submitStatus === 'error'}}">保存失败，重试</block>
        <block wx:else>记下这一刻</block>
      </view>
    </view>
  </view>
</scroll-view>

<!-- 富文本工具栏（常驻底部悬浮） -->
<view class="editor-toolbar" style="bottom: {{keyboardHeight}}px">
  <view class="toolbar-item {{formats.bold ? 'active' : ''}}" data-name="bold" bindtap="format">B</view>
  <view class="toolbar-item {{formats.italic ? 'active' : ''}}" data-name="italic" bindtap="format">I</view>
  <view class="toolbar-item {{formats.header === 3 ? 'active' : ''}}" data-name="header" data-value="3" bindtap="format">H</view>
  <view class="toolbar-divider"></view>
  <view class="toolbar-item {{formats.list === 'bullet' ? 'active' : ''}}" data-name="list" data-value="bullet" bindtap="format">ul</view>
  <view class="toolbar-item {{formats.list === 'ordered' ? 'active' : ''}}" data-name="list" data-value="ordered" bindtap="format">ol</view>
  <view class="toolbar-divider"></view>
  <view class="toolbar-item toolbar-item--with-icon" bindtap="insertImage">
    <app-icon class="toolbar-item-icon" name="camera" size="30rpx"></app-icon>
  </view>
  <view class="toolbar-item toolbar-item--with-icon {{showAudioPanel ? 'active' : ''}}" bindtap="toggleAudioPanel">
    <app-icon class="toolbar-item-icon" name="microphone" size="30rpx"></app-icon>
  </view>
</view>
