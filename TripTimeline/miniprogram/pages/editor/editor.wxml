<!--pages/editor/editor.wxml-->
<navigation-bar title="{{pageTitle}}" back="{{true}}" color="#1C1C1C" background="transparent"></navigation-bar>

<scroll-view class="editor-scroll" scroll-y>
  <view class="editor-container fade-up">
    <view class="page-head">
      <view class="page-title">记录你的旅行瞬间</view>
      <view class="page-subtitle">{{pageSubtitle}}</view>
    </view>

    <view class="type-section">
      <view class="type-chip {{contentType === 'note' ? 'active' : ''}}" data-type="note" bindtap="onTypeChange">文字</view>
      <view class="type-chip {{contentType === 'photo' ? 'active' : ''}}" data-type="photo" bindtap="onTypeChange">图片</view>
      <view class="type-chip {{contentType === 'audio' ? 'active' : ''}}" data-type="audio" bindtap="onTypeChange">音频</view>
      <view class="type-chip {{contentType === 'track' ? 'active' : ''}}" data-type="track" bindtap="onTypeChange">轨迹</view>
    </view>

    <view wx:if="{{contentType === 'photo'}}" class="media-section" bindtap="chooseImage">
      <block wx:if="{{imagePath}}">
        <image class="uploaded-image" src="{{imagePath}}" mode="aspectFill"></image>
        <view class="remove-btn" catchtap="removeImage">X</view>
      </block>
      <block wx:else>
        <view class="empty-media">
          <view class="plus-icon">+</view>
          <view class="empty-text">选择图片并自动识别 EXIF</view>
        </view>
      </block>
    </view>

    <view wx:if="{{contentType === 'audio'}}" class="asset-section">
      <view class="asset-actions-row">
        <view class="asset-action half {{isRecording ? 'disabled' : ''}}" bindtap="startRecordAudio">开始录音</view>
        <view class="asset-action half stop {{!isRecording ? 'disabled' : ''}}" bindtap="stopRecordAudio">结束录音</view>
      </view>
      <view class="recording-tip" wx:if="{{isRecording}}">录音中 {{recordingSeconds}}s / 60s</view>
      <view class="asset-action" bindtap="chooseAudio">或选择音频文件</view>
      <view wx:if="{{audioFileName}}" class="asset-result">已选择：{{audioFileName}}</view>
      <audio wx:if="{{audioPreviewSrc}}" class="audio-player" src="{{audioPreviewSrc}}" controls></audio>
    </view>

    <view wx:if="{{contentType === 'track'}}" class="asset-section">
      <view class="asset-action" bindtap="chooseTrack">导入 GPX/KML 轨迹</view>
      <view wx:if="{{trackFileName}}" class="asset-result">已导入：{{trackFileName}}</view>
      <view wx:if="{{trackPointCount > 0}}" class="asset-result">轨迹点数：{{trackPointCount}}</view>
      <map
        wx:if="{{trackPointCount > 0}}"
        class="track-map"
        latitude="{{trackCenterLatitude}}"
        longitude="{{trackCenterLongitude}}"
        scale="10"
        polyline="{{trackPolyline}}"
        markers="{{trackMarkers}}"
        show-location="{{true}}"
      ></map>
      <view wx:if="{{trackFileName && trackPointCount === 0}}" class="asset-result">当前轨迹暂无可预览坐标</view>
    </view>

    <view class="text-section">
      <input
        class="title-input"
        placeholder="标题（可选）"
        placeholder-class="ph-title"
        value="{{title}}"
        bindinput="onTitleInput"
      />
      <textarea
        class="body-textarea"
        placeholder="输入你的旅行记录内容"
        placeholder-class="ph-body"
        maxlength="-1"
        auto-height
        value="{{content}}"
        bindinput="onContentInput"
      />
    </view>

    <view class="form-section">
      <view class="form-row">
        <text class="form-label">日期</text>
        <picker mode="date" value="{{date}}" bindchange="bindDateChange">
          <view class="picker-value">{{date}}</view>
        </picker>
      </view>

      <view class="form-row">
        <text class="form-label">时间</text>
        <picker mode="time" value="{{time}}" bindchange="bindTimeChange">
          <view class="picker-value">{{time}}</view>
        </picker>
      </view>

      <view class="form-row column">
        <text class="form-label">地点名称</text>
        <input
          class="form-input"
          placeholder="手动输入地点名称"
          value="{{locationName}}"
          bindinput="onLocationNameInput"
        />
      </view>

      <view class="form-row column">
        <text class="form-label">详细地址</text>
        <input
          class="form-input"
          placeholder="手动输入地址"
          value="{{locationAddress}}"
          bindinput="onLocationAddressInput"
        />
      </view>

      <view class="form-row column">
        <text class="form-label">搜索地点</text>
        <view class="search-row">
          <input
            class="form-input search-input"
            placeholder="输入地点名后搜索，如：西湖、天安门"
            value="{{locationSearchKeyword}}"
            bindinput="onLocationSearchInput"
            confirm-type="search"
            bindconfirm="searchLocationByKeyword"
          />
          <view class="search-btn" bindtap="searchLocationByKeyword">{{isLocationSearching ? '搜索中' : '搜索'}}</view>
        </view>
        <view wx:if="{{locationSuggestions.length > 0}}" class="suggestions-list">
          <view
            wx:for="{{locationSuggestions}}"
            wx:key="id"
            class="suggestion-item"
            data-index="{{index}}"
            bindtap="selectSuggestion"
          >
            <view class="suggestion-title">{{item.title}}</view>
            <view class="suggestion-address">{{item.address}}</view>
          </view>
        </view>
      </view>

      <view class="form-row column">
        <view class="loc-actions">
          <view class="loc-btn" bindtap="chooseLocation">地图选点</view>
          <view wx:if="{{autoFillHint}}" class="hint-text">{{autoFillHint}}</view>
        </view>
        <map
          wx:if="{{location && location.lat && location.lon}}"
          class="location-map"
          latitude="{{location.lat}}"
          longitude="{{location.lon}}"
          scale="16"
          markers="{{locationMarker}}"
          bindtap="chooseLocation"
          show-location="{{true}}"
        ></map>
        <view class="coord-text" wx:if="{{location && location.lat && location.lon}}">
          坐标：{{location.lat}}, {{location.lon}}
        </view>
      </view>

      <view class="privacy-block">
        <view class="privacy-title">隐私设置</view>
        <view class="privacy-mode-row">
          <view
            class="privacy-chip {{privacyMode === 'inherit' ? 'active' : ''}}"
            data-mode="inherit"
            bindtap="onPrivacyModeChange"
          >继承项目</view>
          <view
            class="privacy-chip {{privacyMode === 'custom' ? 'active' : ''}}"
            data-mode="custom"
            bindtap="onPrivacyModeChange"
          >单独设置</view>
        </view>
        <view class="privacy-summary">{{privacySummary}}</view>

        <block wx:if="{{privacyMode === 'custom'}}">
          <view class="privacy-picker-wrap">
            <picker mode="selector" range="{{visibilityOptions}}" value="{{privacyVisibilityIndex}}" bindchange="onPrivacyVisibilityChange">
              <view class="privacy-picker">{{visibilityOptions[privacyVisibilityIndex]}}</view>
            </picker>
          </view>
          <view wx:if="{{privacyVisibility === 2}}" class="privacy-whitelist-wrap">
            <input
              class="form-input"
              placeholder="输入白名单用户ID，多个用英文逗号分隔"
              value="{{privacyWhiteListInput}}"
              bindinput="onPrivacyWhiteListInput"
            />
          </view>
        </block>
      </view>
    </view>

    <view class="action-section">
      <view class="save-btn" bindtap="saveEntry">{{saveBtnText}}</view>
    </view>
  </view>
</scroll-view>
