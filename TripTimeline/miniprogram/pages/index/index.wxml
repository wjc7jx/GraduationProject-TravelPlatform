<!--index.wxml-->
<navigation-bar back="{{false}}" color="#1C1C1C" background="transparent">
  <view slot="left" class="editorial-title" style="font-size: 40rpx; height: 100%; display: flex; align-items: center; letter-spacing: 0;">Travel Journals.</view>
</navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">

  <project-filter
    wx:if="{{hasAuth}}"
    bind:filterchange="onFilterChange"
  ></project-filter>

  <!-- 授权与登录状态 -->
  <view wx:if="{{!hasAuth && !isLoading}}" class="empty-state container fade-up" style="animation-delay: 0.3s">
    <image class="empty-icon" src="/assets/img/empty-travel.png" mode="aspectFit"></image>
    <view class="empty-title">欢迎使用旅行时光轴</view>
    <view class="empty-desc">请先授权登录，开启你的专属旅行日记</view>
    <button class="primary-btn" bindtap="onLoginTap">探索旅程 (授权登录)</button>
  </view>

  <!-- 空项目状态 -->
  <view wx:elif="{{hasAuth && projects.length === 0 && !isLoading}}" class="empty-state container fade-up" style="animation-delay: 0.3s">
    <app-icon wx:if="{{hasActiveFilter}}" class="empty-icon" name="search" size="100rpx"></app-icon>
    <app-icon wx:else class="empty-icon" name="globe" size="100rpx"></app-icon>
    <view class="empty-title">{{hasActiveFilter ? '没有匹配的结果' : '第一本旅行日记'}}</view>
    <view class="empty-desc">{{hasActiveFilter ? '请调整筛选条件或关键字后重试' : '还没有记录任何旅行故事，开启你的第一次记录吧'}}</view>
    <button wx:if="{{!hasActiveFilter}}" class="primary-btn" bindtap="onCreateProjectTap">创建新项目</button>
  </view>

  <!-- 瀑布流/非对称卡片展示 -->
  <view wx:else class="gallery-container">
    <block wx:for="{{projects}}" wx:key="id">
      <view class="project-card {{item.style}} {{item.isArchived ? 'is-archived' : ''}} fade-up" style="animation-delay: {{0.2 + index * 0.1}}s" bindtap="goToDetail" bindlongpress="onProjectLongPress" data-id="{{item.id}}">
        <view class="card-image-wrap">
          <image class="card-image" src="{{item.cover}}" mode="aspectFill" lazy-load></image>
          <view class="pin-btn {{item.isPinned ? 'is-pinned' : ''}}" catchtap="onPinTap" data-id="{{item.id}}" data-pinned="{{item.isPinned ? 1 : 0}}">{{item.isPinned ? '取消置顶' : '置顶'}}</view>
          <view class="card-label">{{item.label}}</view>
          <view wx:if="{{item.isArchived}}" class="archived-badge">已归档</view>
        </view>
        
        <view class="card-content">
          <view class="card-meta">
            <text class="card-date">{{item.date}}</text>
            <view class="card-loc-count">
              <app-icon class="card-loc-count-icon" name="location" size="24rpx"></app-icon>
              <text>{{item.locationCount}} 个足迹</text>
            </view>
          </view>
          <view class="card-title">{{item.title}}</view>
          <view class="card-subtitle">{{item.subtitle}}</view>
        </view>
      </view>
    </block>
  </view>
</scroll-view>

