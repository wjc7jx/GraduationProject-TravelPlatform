<navigation-bar title="我的" back="{{false}}" color="#1C1C1C" background="#F7F5F0"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="profile-hero">
    <view class="hero-title">旅行回顾中心</view>
    <view class="hero-subtitle">查看年度足迹与项目总结</view>
    <button class="invite-btn" open-type="share" bindtap="onInviteTap">微信卡片邀请好友</button>
    <view class="invite-code-card">
      <view class="invite-code-label">我的邀请码</view>
      <view class="invite-code-value">{{inviteCode || '暂未生成'}}</view>
      <view wx:if="{{inviteCodeExpireAt}}" class="invite-code-expire">24小时有效，过期时间：{{inviteCodeExpireAt}}</view>
      <button class="invite-refresh-btn" bindtap="onInviteTap" loading="{{creatingInviteCode}}">刷新邀请码</button>
      <view class="invite-input-row">
        <input
          class="invite-input"
          type="text"
          maxlength="32"
          placeholder="输入好友邀请码"
          value="{{inviteCodeInput}}"
          bindinput="onInviteCodeInput"
        />
        <button class="invite-apply-btn" bindtap="onApplyInviteCodeTap" loading="{{applyingInviteCode}}">添加</button>
      </view>
    </view>
    <view class="review-entry" bindtap="goToYearReview">
      <view class="entry-title">年度回顾</view>
      <view class="entry-desc">按年份汇总所有项目，并在地图中回顾足迹</view>
    </view>
  </view>

<view class="friend-section">
  <view class="section-title">我的好友</view>

  <!-- 加载中 -->
  <view wx:if="{{isLoadingFriends}}" class="friend-loading">加载中...</view>

  <!-- 无好友 -->
  <view wx:elif="{{!isLoadingFriends && friends.length === 0}}" class="friend-empty">还没有好友，先邀请一个吧</view>

  <!-- 有好友：单独一个 block 或 view 包裹列表 -->
  <block wx:else>
    <block wx:for="{{friends}}" wx:key="user_id">
      <view class="friend-item">
        <image wx:if="{{item.avatar_url}}" class="friend-avatar" src="{{item.avatar_url}}" mode="aspectFill"></image>
        <view wx:else class="friend-avatar friend-avatar-fallback">友</view>
        <view class="friend-info">
          <view class="friend-name">{{item.nickname || ('用户' + item.user_id)}}</view>
          <view class="friend-id">ID: {{item.user_id}}</view>
        </view>
      </view>
    </block>
  </block>
</view>

</scroll-view>
