<navigation-bar title="我的" back="{{false}}" color="#1C1C1C" background="#F7F5F0"></navigation-bar>

<scroll-view class="scrollarea" scroll-y type="list">
  <view class="profile-hero">
    <view class="hero-greeting">{{greetingTitle}}</view>
    <view class="hero-stat">{{heroStatLine}}</view>
  </view>

  <view class="profile-body">
    <view class="user-profile-card">
      <view class="user-profile-card-title">个人资料</view>
      <view class="user-profile-hint">点击头像使用微信头像；昵称用于问候与旅伴展示（需你主动选择，无法静默读取）。</view>

      <view class="user-profile-row">
        <view
          class="profile-avatar-btn"
          bindtap="onChooseAvatarTap"
          disabled="{{!hasToken}}"
        >
          <image wx:if="{{avatarDisplaySrc}}" class="profile-avatar-img" src="{{avatarDisplaySrc}}" mode="aspectFill"></image>
          <view wx:else class="profile-avatar-placeholder">我</view>
        </view>

        <view class="user-profile-fields">
          <view class="profile-field-label">昵称</view>
          <input
            class="profile-nickname-input"
            type="nickname"
            maxlength="50"
            placeholder="填写昵称"
            model:value="{{profileNickname}}"
            disabled="{{!hasToken}}"
            bindblur="onProfileNicknameBlur"
          />
        </view>
      </view>

      <button
        class="profile-save-btn"
        bindtap="onSaveProfileTap"
        loading="{{savingProfile}}"
        disabled="{{!hasToken || savingProfile}}"
      >
        保存资料
      </button>
    </view>

    <view class="invite-card">
      <view class="invite-card-title">邀请好友</view>

      <view class="invite-code-row">
        <text class="invite-code-value" selectable>{{inviteCode || '暂未生成'}}</text>
        <view class="invite-code-actions">
          <view class="invite-icon-btn" bindtap="onCopyInviteCode">
            <app-icon name="copy" size="32rpx" color="#2A4B3C" custom-class="invite-action-icon"></app-icon>
          </view>
          <view class="invite-icon-btn {{creatingInviteCode ? 'is-busy' : ''}}" bindtap="onRefreshInviteTap">
            <app-icon name="refresh" size="32rpx" color="#2A4B3C" custom-class="invite-action-icon"></app-icon>
          </view>
        </view>
      </view>
      <view wx:if="{{inviteCodeExpireAt}}" class="invite-code-expire">24 小时有效，过期时间：{{inviteCodeExpireAt}}</view>

      <view class="invite-input-block">
        <view class="invite-input-label">输入好友邀请码</view>
        <view class="invite-input-row">
          <input
            class="invite-input"
            type="text"
            maxlength="32"
            placeholder="好友的邀请码"
            value="{{inviteCodeInput}}"
            bindinput="onInviteCodeInput"
          />
          <button class="invite-apply-btn" bindtap="onApplyInviteCodeTap" loading="{{applyingInviteCode}}">添加</button>
        </view>
      </view>
    </view>

    <view class="year-review-card" bindtap="goToYearReview">
      <view class="year-review-left">
        <app-icon name="world" size="44rpx" color="#FFFFFF" custom-class="year-review-icon"></app-icon>
        <view class="year-review-texts">
          <view class="year-review-title">{{reviewYearTitle}}</view>
          <view class="year-review-sub">{{reviewSummaryLine}}</view>
        </view>
      </view>
      <text class="year-review-chevron">›</text>
    </view>

    <view class="friends-section">
      <view class="friends-section-title">旅伴</view>

      <view wx:if="{{isLoadingFriends}}" class="friend-loading">加载中…</view>
      <view wx:elif="{{!isLoadingFriends && friends.length === 0}}" class="friend-empty">还没有旅伴，先邀请一位吧</view>
      <block wx:else>
        <block wx:for="{{friends}}" wx:key="user_id">
          <view class="friend-card">
            <image wx:if="{{item.avatar_url}}" class="friend-avatar" src="{{item.avatar_url}}" mode="aspectFill"></image>
            <view wx:else class="friend-avatar friend-avatar-fallback">友</view>
            <view class="friend-info">
              <view class="friend-name">{{item.nickname || ('用户' + item.user_id)}}</view>
              <view class="friend-meta">ID {{item.user_id}}</view>
            </view>
          </view>
        </block>
      </block>
    </view>
  </view>
</scroll-view>
