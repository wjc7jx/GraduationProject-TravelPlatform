<!--pages/project-detail/project-detail.wxml-->
<view class="container">

  <!-- 顶部封面与信息 -->
  <view class="header-banner">
    <view class="back-btn" bindtap="goBack">
      <app-icon class="back-icon"  name="backIcon" size="48rpx" color="#8A877E"></app-icon>
    </view>
    <view wx:if="{{isOwner}}" class="edit-btn" bindtap="onManageProjectTap">
      <view class="edit-icon">管理</view>
    </view>
    <image class="cover-image" src="{{projectDetail.cover}}" mode="aspectFill"></image>
    <view class="overlay">
      <view class="project-info">
        <text class="date">{{projectDetail.date}}</text>
        <text class="title">{{projectDetail.title}}</text>
        <text wx:if="{{projectDetail.isArchived}}" class="archive-tag">已归档</text>
        <text class="subtitle">{{projectDetail.subtitle}}</text>
      </view>
    </view>
  </view>

  <!-- 操作导航区 -->
  <view class="action-grid">
    <!-- 进入时间轴与地图 -->
    <view class="action-card primary" bindtap="goToTimelineMap">
      <app-icon class="icon" name="map" size="56rpx"></app-icon>
      <view class="text-group">
        <text class="main">故事地图</text>
        <text class="sub">查看我的路线与回忆</text>
      </view>
      <view class="arrow">→</view>
    </view>

    <!-- 新建打卡内容 -->
    <view wx:if="{{isOwner && !projectDetail.isArchived}}" class="action-card secondary" bindtap="goToEditor">
      <app-icon class="icon" name="edit" size="56rpx"></app-icon>
      <view class="text-group">
        <text class="main">写新日志</text>
        <text class="sub">记录当下的足迹与感受</text>
      </view>
      <view class="arrow">+</view>
    </view>

    <!-- 分享与导出（合并卡片）-->
    <view class="action-card tertiary share-export-card">
      <button wx:if="{{isOwner}}" class="share-col" open-type="share">
        <app-icon class="share-icon" name="link" size="48rpx"></app-icon>
        <text class="share-label">小程序分享</text>
      </button>
      <view wx:if="{{isOwner}}" class="share-divider"></view>
      <view wx:if="{{isOwner}}" class="share-col" bindtap="onInternalShareTap">
        <app-icon class="share-icon" name="mobile" size="48rpx"></app-icon>
        <text class="share-label">口令/二维码</text>
      </view>
      <view wx:if="{{isOwner}}" class="share-divider"></view>
      <view class="share-col" bindtap="onExportTap">
        <app-icon class="share-icon" name="export" size="48rpx"></app-icon>
        <text class="share-label">导出纪念册</text>
      </view>
    </view>
  </view>

  <!-- 这里可以未来添加该项目下最新的几条日记预览 / 统计信息 -->
  <view class="stats-section">
    <view class="section-title">旅行概览</view>
    <view class="stats-cards">
      <view class="stat-card">
        <text class="num">{{stats.locations}}</text>
        <text class="label">足迹点</text>
      </view>
      <view class="stat-card">
        <text class="num">{{stats.photos}}</text>
        <text class="label">照片</text>
      </view>
      <view class="stat-card">
        <text class="num">{{stats.days}}</text>
        <text class="label">天数</text>
      </view>
    </view>
  </view>

  <!-- 单一入口：直接进入统一 editor -->
  <view wx:if="{{isOwner && !projectDetail.isArchived}}" class="fab-container">
    <view class="fab-trigger" bindtap="goToEditor">
      <app-icon class="fab-cross" name="edit" size="56rpx"></app-icon>
    </view>
  </view>

</view>