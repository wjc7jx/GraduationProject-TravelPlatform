<!--pages/project-detail/project-detail.wxml-->
<view class="container">

  <!-- 顶部封面与信息 -->
  <view class="header-banner">
    <view class="back-btn" bindtap="goBack">
      <app-icon class="back-icon"  name="backIcon" size="48rpx" color="#fff"></app-icon>
    </view>
    <image class="cover-image" src="{{projectDetail.cover}}" mode="aspectFill"></image>
    <view class="overlay">
      <view class="project-info">
        <text class="date">{{projectDetail.date}}</text>
        <text class="title">{{projectDetail.title}}</text>
        <text wx:if="{{projectDetail.isArchived}}" class="archive-tag">已归档</text>
        <text class="subtitle">{{projectDetail.subtitle}}</text>
      </view>
    </view>
  </view>

  <!-- 合规风险横幅 -->
  <view wx:if="{{reviewFlagged}}" class="review-banner">
    <view class="review-banner-title">⚠ 该项目存在合规风险内容</view>
    <view wx:if="{{reviewScope === 'project'}}" class="review-banner-desc">项目信息（标题/副标题/标签）被判定存在风险，请点击右下角「管理」→「编辑项目」调整后重新保存。</view>
    <view wx:elif="{{reviewScope === 'content'}}" class="review-banner-desc">共 {{flaggedContentCount}} 条记录被判定存在风险，请进入对应记录修改。未解除前本项目无法导出或分享。</view>
    <view wx:else class="review-banner-desc">请先定位到被标记的记录并修改，解除风险后即可导出或分享。</view>
  </view>

  <!-- 操作导航区 -->
  <view class="action-grid">
    <!-- 进入时间轴与地图 -->
    <view class="action-card primary" bindtap="goToTimelineMap">
      <app-icon class="icon" name="map" size="56rpx" color="#fff"></app-icon>
      <view class="text-group">
        <text class="main">故事地图</text>
        <text class="sub">查看我的路线与回忆</text>
      </view>
            <app-icon class="icon" name="enter" size="56rpx" color="#fff"></app-icon>
    </view>

    <!-- 次级操作行 -->
    <view class="sub-action-row">
      <view class="action-card secondary" bindtap="goToEditor">
        <app-icon class="icon" name="edit" size="40rpx" color="#2A4B3C"></app-icon>
        <text class="label">写记录</text>
      </view>
      <view class="action-card secondary" bindtap="showMoreActions">
        <app-icon class="icon" name="export" size="40rpx" color="#2A4B3C"></app-icon>
        <text class="label">分享/导出</text>
      </view>
    </view>
  </view>

  <!-- 这里可以未来添加该项目下最新的几条日记预览 / 统计信息 -->
  <view class="stats-section">
    <view class="stats-cards">
      <view class="stat-card">
        <text class="num">{{stats.locations}}</text>
        <text class="label">足迹点</text>
      </view>
      <view class="stat-card">
        <text class="num">{{stats.photos}}</text>
        <text class="label">照片</text>
      </view>
      <view class="stat-card">
        <text class="num">{{stats.days}}</text>
        <text class="label">天数</text>
      </view>
    </view>
  </view>

  <!-- 右下角悬浮按钮组 -->
  <view class="fab-group">
    <!-- 管理按钮：始终在该组顶部显示 -->
    <view wx:if="{{isOwner}}" class="fab-trigger fab-manage" bindtap="onManageProjectTap">
      <app-icon class="fab-icon" name="settings" size="48rpx" color="#2e2a25"></app-icon>
    </view>
  </view>

</view>