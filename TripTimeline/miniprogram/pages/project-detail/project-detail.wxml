<!--pages/project-detail/project-detail.wxml-->
<view class="container">
  
  <!-- 顶部封面与信息 -->
  <view class="header-banner">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon">←</view>
    </view>
    <view class="edit-btn" bindtap="goToProjectEditor">
      <view class="edit-icon">编辑</view>
    </view>
    <image class="cover-image" src="{{projectDetail.cover}}" mode="aspectFill"></image>
    <view class="overlay">
      <view class="project-info">
        <text class="date">{{projectDetail.date}}</text>
        <text class="title">{{projectDetail.title}}</text>
        <text class="subtitle">{{projectDetail.subtitle}}</text>
      </view>
    </view>
  </view>

  <!-- 操作导航区 -->
  <view class="action-grid">
    <!-- 进入时间轴与地图 -->
    <view class="action-card primary" bindtap="goToTimelineMap">
      <view class="icon">🗺️</view>
      <view class="text-group">
        <text class="main">故事地图</text>
        <text class="sub">查看我的路线与回忆</text>
      </view>
      <view class="arrow">→</view>
    </view>

    <!-- 新建打卡内容 -->
    <view class="action-card secondary" bindtap="goToEditor">
      <view class="icon">✍️</view>
      <view class="text-group">
        <text class="main">写新日志</text>
        <text class="sub">记录当下的足迹与感受</text>
      </view>
      <view class="arrow">+</view>
    </view>
  </view>

  <!-- 这里可以未来添加该项目下最新的几条日记预览 / 统计信息 -->
  <view class="stats-section">
    <view class="section-title">旅行概览</view>
    <view class="stats-cards">
      <view class="stat-card">
        <text class="num">{{stats.locations}}</text>
        <text class="label">足迹点</text>
      </view>
      <view class="stat-card">
        <text class="num">{{stats.photos}}</text>
        <text class="label">照片</text>
      </view>
      <view class="stat-card">
        <text class="num">{{stats.days}}</text>
        <text class="label">天数</text>
      </view>
    </view>
  </view>

  <!-- 杂志风悬浮内容发布菜单 (FAB) -->
  <view class="fab-container {{showFabMenu ? 'active' : ''}}">
    <view class="fab-backdrop" bindtap="toggleFabMenu"></view>
    <view class="fab-menu">
      <view class="fab-item" bindtap="onAddTrack" style="transition-delay: 0.1s">
        <view class="fab-label">导入轨迹 (GPX)</view>
        <view class="fab-icon-btn">🗺️</view>
      </view>
      <view class="fab-item" bindtap="onAddAudio" style="transition-delay: 0.05s">
        <view class="fab-label">录制语音</view>
        <view class="fab-icon-btn">🎙️</view>
      </view>
      <view class="fab-item" bindtap="onAddPhoto" style="transition-delay: 0s">
        <view class="fab-label">极速传图 (自动取点)</view>
        <view class="fab-icon-btn">📸</view>
      </view>
    </view>
    <view class="fab-trigger" bindtap="toggleFabMenu">
      <view class="fab-cross">+</view>
    </view>
  </view>

</view>
