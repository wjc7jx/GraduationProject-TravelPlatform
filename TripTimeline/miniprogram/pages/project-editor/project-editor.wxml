<!--pages/project-editor/project-editor.wxml-->
<navigation-bar title="{{isEdit ? '编辑旅行' : '新建旅行'}}" back="{{true}}" color="#1C1C1C" background="#F7F5F0"></navigation-bar>

<view class="container">

  <view class="form-section">
    <!-- 主标题 -->
    <view class="form-item">
      <view class="label">项目标题 <text class="required">*</text></view>
      <input class="input-field header-input" placeholder="给这次旅行起个名字 (如: 京都漫步)" value="{{title}}" bindinput="onTitleInput" />
    </view>

    <!-- 副标题 -->
    <view class="form-item">
      <view class="label">副标题</view>
      <input class="input-field" placeholder="一句话描述 (如: 寻迹红色与枯山水)" value="{{subtitle}}" bindinput="onSubtitleInput" />
    </view>

    <!-- 时间选择 -->
    <view class="form-row">
      <view class="form-item half">
        <view class="label">出发日期 <text class="required">*</text></view>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="date-picker">{{startDate || '选择日期'}}</view>
        </picker>
      </view>
      <view class="form-item half">
        <view class="label">结束日期 <text class="required">*</text></view>
        <picker mode="date" value="{{endDate}}" start="{{startDate}}" bindchange="onEndDateChange">
          <view class="date-picker">{{endDate || '选择日期'}}</view>
        </picker>
      </view>
    </view>

    <!-- 旅行标签 -->
    <view class="form-item">
      <view class="label">旅行标签 (最多5个)</view>
      <view class="tags-container">
        <block wx:for="{{tags}}" wx:key="*this">
          <view class="tag-item">
            <text>{{item}}</text>
            <view class="tag-close" bindtap="removeTag" data-index="{{index}}">×</view>
          </view>
        </block>
        <view class="tag-input-wrap" wx:if="{{tags.length < 5}}">
          <input class="tag-input" placeholder="输入后按回车" value="{{tagInput}}" bindinput="onTagInput" bindconfirm="addTag" confirm-type="done" />
        </view>
      </view>
    </view>

    <view class="form-item">
      <view class="label">专辑封面 <text class="required">*</text></view>
      <view class="cover-grid-row">
        <block wx:for="{{coverImages}}" wx:key="index">
          <view class="cover-card {{selectedCoverIndex === index ? 'active' : ''}}" bindtap="onSelectCover" data-index="{{index}}">
            <image class="cover-thumb" src="{{item}}" mode="aspectFill"></image>
            <view class="cover-remove" catchtap="removeCover" data-index="{{index}}">×</view>
          </view>
        </block>

        <view wx:if="{{coverImages.length < 3}}" class="cover-card add-card" bindtap="chooseCover">
          <text class="plus">+</text>
        </view>
      </view>
      <view class="cover-hint">可上传1~3张，点击图片可设为首图（带深色边框）</view>
    </view>

    <view class="form-item">
      <view class="label">默认可见性</view>
      <picker mode="selector" range="{{visibilityOptions}}" value="{{privacyVisibilityIndex}}" bindchange="onPrivacyVisibilityChange">
        <view class="date-picker">{{visibilityOptions[privacyVisibilityIndex]}}</view>
      </picker>
      <view class="privacy-hint">{{privacyHint}}</view>
      <view class="privacy-tip" wx:if="{{privacyVisibility === 2}}">好友可见将基于双方是否建立好友关系自动判定</view>
    </view>
  </view>

  <view class="bottom-action-row">
    <view class="btn-complete {{submitting ? 'disabled' : ''}}" bindtap="onSubmit">
      {{submitting ? '提交中' : (isEdit ? '保存修改' : '完成')}}
    </view>
  </view>

</view>
