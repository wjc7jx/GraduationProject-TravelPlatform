<!--pages/timeline-map/timeline-map.wxml-->
<navigation-bar title="{{timelineTitle}}" back="{{true}}" color="#1C1C1C" background="rgba(247,245,240,0.85)"></navigation-bar>

<view class="page-container">
  <!-- 沉浸式地图 (满屏底层) -->
  <map
    id="storyMap"
    class="story-map fade-up"
    style="animation-delay: 0.1s"
    longitude="{{centerLon}}"
    latitude="{{centerLat}}"
    scale="{{mapScale}}"
    markers="{{markers}}"
    polyline="{{polylines}}"
    circles="{{circles}}"
    enable-cluster="{{true}}"
    bindmarkertap="onMarkerTap"
    bindmarkerclustertap="onMarkerClusterTap"
    bindtap="onMapTap"
    bindregionchange="onMapRegionChange"
    show-location
  ></map>

  <view class="share-badge" wx:if="{{isShareView}}">分享浏览模式</view>

  <!-- A7：未定位节点提醒条（点击跳到第一条未定位记录） -->
  <view class="no-loc-hint" wx:if="{{noLocCount > 0}}" bindtap="onNoLocHintTap">
    <view class="no-loc-dot"></view>
    <text class="no-loc-text">{{noLocCount}} 条记录缺少定位</text>
    <text class="no-loc-cta" wx:if="{{!isShareView}}">去补充</text>
    <text class="no-loc-cta" wx:else>查看</text>
  </view>

  <!-- A8：当前激活节点在有定位序列中的进度 -->
  <view class="progress-badge" wx:if="{{locatedCount > 0 && progressCurrent > 0}}">
    <text class="progress-current">{{progressCurrent}}</text>
    <text class="progress-sep">/</text>
    <text class="progress-total">{{locatedCount}}</text>
    <text class="progress-label">站</text>
  </view>

  <!-- UX：常驻"回到全览"胶囊；在按天筛选或手势偏离时高亮并改文案 -->
  <view class="map-tools" wx:if="{{locatedCount > 1}}">
    <view
      class="map-tool-btn {{(showResetViewport || activeDayDate) ? 'is-active' : ''}}"
      bindtap="onResetViewportTap"
    >{{activeDayDate ? '返回全程' : '回到全览'}}</view>
  </view>

  <!-- 底部可拖拽抽屉 -->
  <view class="bottom-sheet" style="height: {{sheetHeight}}vh; transition: {{isDragging ? 'none' : 'height 0.4s cubic-bezier(0.2, 0.8, 0.2, 1)'}}">
    <!-- 拖拽把手区 -->
    <view class="drag-handle-wrapper" catchtouchstart="onTouchStart" catchtouchmove="onTouchMove" catchtouchend="onTouchEnd">
      <view class="drag-handle"></view>
    </view>

    <!-- 纸质感玻璃态时间轴 -->
    <view class="timeline-panel fade-up" style="animation-delay: 0.2s">
      <scroll-view 
        class="timeline-scroll" 
        scroll-y 
        scroll-into-view="{{scrollToId}}" 
        scroll-with-animation
        enhanced
        show-scrollbar="{{false}}"
      >
        <view class="timeline-track">
          
          <!-- 导语区 -->
          <view class="timeline-header" wx:if="{{projectDetail}}">
            <view class="chapter-text">旅行记忆</view>
            <view class="editorial-title" style="font-size: 44rpx;">{{projectDetail.title || '出发'}}.</view>
            <view class="editorial-subtitle" style="margin-top: 10rpx;">一段记录了 {{markers.length}} 个足迹的奇妙旅程。</view>
          </view>

          <!-- 节点列表 (按天分组) -->
          <block wx:for="{{timelineData}}" wx:key="date" wx:for-item="dayGroup" wx:for-index="gIndex">
            <view
              class="timeline-day-header {{activeDayDate === dayGroup.date ? 'is-active' : ''}}"
              data-date="{{dayGroup.date}}"
              bindtap="onDayHeaderTap"
            >
              <text class="day-text">{{dayGroup.date}}</text>
              <text class="day-cta">{{activeDayDate === dayGroup.date ? '仅看此日 · 取消' : '仅看此日'}}</text>
            </view>
            
            <block wx:for="{{dayGroup.items}}" wx:key="id">
              <!-- 手风琴节点 -->
              <view class="timeline-node {{activeIndex === item.globalIndex ? 'active' : ''}}" id="node-{{item.id}}" bindtap="onNodeTap" bindlongpress="onNodeLongPress" data-index="{{item.globalIndex}}">
                <!-- 左侧：线与地理标记原点 -->
                <view class="node-axis">
                  <view class="node-dot {{!item.hasLoc ? 'no-loc' : ''}}"></view>
                  <view class="node-line" wx:if="{{index !== dayGroup.items.length - 1 || gIndex !== timelineData.length - 1}}"></view>
                </view>
                
                <!-- 右侧：叙事内容 -->
                <view class="node-content">
                  <view class="node-header-row">
                    <view class="node-meta">
                      <text class="node-time">{{item.time}}</text>
                      <text class="node-category">{{item.category}}</text>
                    </view>
                    <!-- 折叠时显示首图缩略 + 标题（A6） -->
                    <view class="collapsed-row" wx:if="{{activeIndex !== item.globalIndex}}">
                      <image
                        wx:if="{{item.images && item.images.length > 0}}"
                        class="collapsed-thumb"
                        src="{{item.images[0]}}"
                        mode="aspectFill"
                        lazy-load
                      ></image>
                      <view class="node-title collapsed-title">{{item.title}}</view>
                    </view>
                  </view>
                  
                  <!-- 只有在激活(active)状态下才展开的内容区域 -->
                  <view class="node-details" wx:if="{{activeIndex === item.globalIndex}}">
                    <view class="node-title">{{item.title}}</view>
                    <rich-text class="node-html" nodes="{{item.richContent}}" wx:if="{{item.richContent}}"></rich-text>
                    
                    <!-- 多图布局（独立图片区） -->
                    <view class="node-media" wx:if="{{item.images && item.images.length > 0}}">
                      <!-- 1 张 -->
                      <view wx:if="{{item.images.length === 1}}" class="img-layout img-layout--one">
                        <image src="{{item.images[0]}}" class="img-one" mode="aspectFill" lazy-load></image>
                      </view>

                      <!-- 2 张 -->
                      <view wx:elif="{{item.images.length === 2}}" class="img-layout img-layout--two">
                        <image src="{{item.images[0]}}" class="img-two" mode="aspectFill" lazy-load></image>
                        <image src="{{item.images[1]}}" class="img-two" mode="aspectFill" lazy-load></image>
                      </view>

                      <!-- ≥3 张 -->
                      <view wx:else class="img-layout img-layout--three">
                        <image src="{{item.images[0]}}" class="img-left" mode="aspectFill" lazy-load></image>
                        <view class="img-right-col">
                          <image src="{{item.images[1]}}" class="img-right" mode="aspectFill" lazy-load></image>
                          <view class="img-right-wrap">
                            <image src="{{item.images[2]}}" class="img-right" mode="aspectFill" lazy-load></image>
                            <view class="img-more" wx:if="{{item.images.length > 3}}">+{{item.images.length - 3}}</view>
                          </view>
                        </view>
                      </view>
                    </view>

                    <!-- 音频小控件 -->
                    <view class="audio-player-mini" wx:if="{{item.audio}}" catchtap="onToggleAudio" data-id="{{item.id}}" data-url="{{item.audio.url}}">
                      <view class="mini-play-btn {{playingAudioId === item.id ? 'is-playing' : ''}}">
                        <app-icon name="{{playingAudioId === item.id ? 'pause' : 'play'}}" size="28rpx"></app-icon>
                      </view>
                      <view class="mini-audio-info">
                        <text class="mini-audio-name">{{item.audio.name}}</text>
                        <text class="mini-audio-status">{{playingAudioId === item.id ? '正在播放...' : '点击播放'}}</text>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </block>
          </block>

          <view class="end-mark">
            <text class="end-mark-line"></text>
            <text class="end-mark-text">全部看完了</text>
            <text class="end-mark-line"></text>
          </view>

          <!-- 留白用于避免FAB遮挡内容 -->
          <view style="height: 120px;"></view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 单一入口：直接进入统一 editor -->
  <view wx:if="{{!isProjectArchived && !isShareView}}" class="fab-container">
    <view class="fab-trigger" bindtap="goToEditor">
      <app-icon class="fab-cross" name="edit" size="56rpx"></app-icon>
    </view>
  </view>

</view>
