# Export (optional)
# Set this only when Chrome/Chromium is not auto-detected by Puppeteer.
# Example: C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# 对象存储（七牛直传；小程序经 /upload/qiniu-token 取凭证后直传 up 域名）
# STORAGE_DRIVER=local 保留 multer 本地上传；=qiniu 关闭本地上传路由（仅直传）
STORAGE_DRIVER=local
QINIU_ACCESS_KEY=kKMPrbOR8aDE6Ku3nny3sszlR4zpHYx2mu80XPpE
QINIU_SECRET_KEY=U0rApLVwNgeLY3fVxy2t1BqEXB1_JNtwoT2Am06o
QINIU_BUCKET=trip-timeline-oss
# 区域：z0 z1 z2 na0 as0（须与空间区域一致）
