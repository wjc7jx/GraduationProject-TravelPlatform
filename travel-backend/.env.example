# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=travel_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Export (optional)
# Set this only when Chrome/Chromium is not auto-detected by Puppeteer.
# Example: C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# 对象存储（七牛直传；小程序经 /upload/qiniu-token 取凭证后直传 up 域名）
# STORAGE_DRIVER=local 保留 multer 本地上传；=qiniu 关闭本地上传路由（仅直传）
STORAGE_DRIVER=local
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
# 区域：z0 z1 z2 na0 as0（须与空间区域一致）
QINIU_ZONE=z0
# QINIU_PUBLIC_BASE_URL 必须与控制台外链域名一致；可写完整 http:// 或 https://，仅写域名时由 QINIU_PUBLIC_SCHEME 补协议（默认 https）
# 外链只能用 http 时：QINIU_PUBLIC_SCHEME=http 且 QINIU_PUBLIC_BASE_URL=http://你的域名 或裸域名
# 若上传成功但图片打不开：公开读、防盗链、浏览器打开 URL 看 403/404
QINIU_PUBLIC_SCHEME=https
QINIU_PUBLIC_BASE_URL=
