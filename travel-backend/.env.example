# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=10.238.184.74
DB_PORT=3306
DB_NAME=travel_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=replace_with_strong_secret
