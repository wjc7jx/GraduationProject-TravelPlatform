# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=10.238.184.74
DB_PORT=3306
DB_NAME=travel_db
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# Export (optional)
# Set this only when Chrome/Chromium is not auto-detected by Puppeteer.
# Example: C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
PUPPETEER_EXECUTABLE_PATH=
